{
  "name": "pi-scheduled-router",
  "version": "0.1.1",
  "description": "Switch Pi's AI provider and model based on time of day via YAML time-slot configuration.",
  "type": "module",
  "license": "MIT",
  "author": "eiei114",
  "keywords": [
    "pi-package",
    "pi",
    "agent-skill",
    "typescript",
    "model-router",
    "scheduled"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/eiei114/pi-scheduled-router.git"
  },
  "bugs": {
    "url": "https://github.com/eiei114/pi-scheduled-router/issues"
  },
  "homepage": "https://github.com/eiei114/pi-scheduled-router#readme",
  "files": [
    "extensions/",
    "lib/",
    "docs/",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "node --test tests/*.test.mjs",
    "ci": "npm run typecheck && npm test && npm run pack:check",
    "pack:check": "npm pack --dry-run",
    "version:check": "node scripts/check-version-bump.mjs"
  },
  "pi": {
    "extensions": [
      "./extensions"
    ]
  },
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*",
    "typebox": "*"
  },
  "devDependencies": {
    "@earendil-works/pi-ai": "latest",
    "@earendil-works/pi-coding-agent": "latest",
    "@earendil-works/pi-tui": "latest",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.9.3",
    "typebox": "latest",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "js-yaml": "^4.2.0"
  }
}
